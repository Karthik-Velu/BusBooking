                    <div class="space-y-3">
                        <label class="flex items-center p-4 border rounded-lg has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-500 transition-all"><img src="https://placehold.co/40x40/E9D5FF/6D28D9?text=UPI" class="rounded-md mr-4" alt="UPI" onerror="this.onerror=null;this.src='https://placehold.co/40x40/E9D5FF/6D28D9?text=UPI';"><span class="font-semibold">UPI / QR</span><input type="radio" name="payment-method" class="ml-auto" checked></label>
                        <label class="flex items-center p-4 border rounded-lg has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-500 transition-all"><img src="https://placehold.co/40x40/C7D2FE/4338CA?text=Card" class="rounded-md mr-4" alt="Card" onerror="this.onerror=null;this.src='https://placehold.co/40x40/C7D2FE/4338CA?text=Card';"><span class="font-semibold">Credit/Debit Card</span><input type="radio" name="payment-method" class="ml-auto"></label>
                        <label class="flex items-center p-4 border rounded-lg has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-500 transition-all"><img src="https://placehold.co/40x40/A5F3FC/0891B2?text=NB" class="rounded-md mr-4" alt="Net Banking" onerror="this.onerror=null;this.src='https://placehold.co/40x40/A5F3FC/0891B2?text=NB';"><span class="font-semibold">Net Banking</span><input type="radio" name="payment-method" class="ml-auto"></label>
                    </div>
                </div>
                <div class="fixed bottom-0 left-0 right-0 max-w-md mx-auto p-4 bg-white border-t"><button class="action-btn w-full bg-green-600 text-white font-bold py-3.5 rounded-lg" data-action="pay">Pay Securely</button></div>`;
        }

        function renderConfirmationScreen() {
            document.getElementById('confirmation').innerHTML = `
                <div class="flex flex-col items-center justify-center text-center p-4 h-full">
                    <div class="bg-green-100 rounded-full p-4"><i data-lucide="check" class="h-16 w-16 text-green-600"></i></div>
                    <h1 class="text-2xl font-bold mt-6">Booking Confirmed!</h1>
                    <p class="text-gray-600 mt-2">Your QR ticket is ready.</p>
                    <div class="bg-white p-4 rounded-lg mt-8 shadow-lg"><img src="https://placehold.co/200x200/FFFFFF/000000?text=QR+Code" alt="QR Code" class="rounded-md" onerror="this.onerror=null;this.src='https://placehold.co/200x200/FFFFFF/000000?text=QR';"></div>
                    <p class="mt-4 font-semibold">Bus ${appData.busDetails.name} - ${bookingState.from} to ${bookingState.to}</p>
                    <button class="action-btn w-full max-w-xs mt-8 bg-indigo-600 text-white font-bold py-3.5 rounded-lg" data-action="navigate" data-target="home">Back to Home</button>
                </div>`;
        }

        // --- Component Rendering ---
        function renderSeatMap() {
            const container = document.getElementById('seat-map-container');
            if (!container) return;
            container.innerHTML = `<div class="flex justify-between items-center mb-4 px-2"><i data-lucide="circle-user-round" class="h-8 w-8 text-gray-600" title="Driver"></i><i data-lucide="door-open" class="h-8 w-8 text-gray-600" title="Exit"></i></div>`;
            const bus = appData.busDetails;
            let seatNumber = 1;
            const rows = Math.ceil(bus.totalSeats / 4);
            
            for (let i = 0; i < rows; i++) {
                const rowEl = document.createElement('div');
                rowEl.className = 'seat-row mb-2';
                for (let j = 0; j < 5; j++) {
                    if (j === 2) { rowEl.innerHTML += `<div class="aisle"></div>`; continue; }
                    if (seatNumber > bus.totalSeats) continue;
                    let classes = 'seat action-btn';
                    if (bus.bookedSeats.includes(seatNumber)) classes += ' booked';
                    else if (bus.ladiesSeats.includes(seatNumber)) classes += ' ladies';
                    else classes += ' available';
                    rowEl.innerHTML += `<div class="${classes}" data-action="select-seat" data-seat-number="${seatNumber}">${seatNumber}</div>`;
                    seatNumber++;
                }
                container.appendChild(rowEl);
            }
        }

        // --- Update Functions ---
        function updateStandingSummary() {
            const { count, price } = bookingState.ticket;
            document.getElementById('standing-count').textContent = count;
            document.getElementById('standing-summary').textContent = `${count} Ticket(s)`;
            document.getElementById('standing-total-price').textContent = `₹${price}`;
        }

        function updateSeatSummary() {
            const { seatNumber, price } = bookingState.ticket;
            const summaryEl = document.getElementById('seat-summary');
            const priceEl = document.getElementById('seat-total-price');
            const proceedBtn = document.getElementById('seat-proceed-btn');

            if (seatNumber) {
                summaryEl.textContent = `Seat ${seatNumber}`;
                priceEl.textContent = `₹${price}`;
                proceedBtn.disabled = false;
            } else {
                summaryEl.textContent = 'Select a seat';
                priceEl.textContent = '';
                proceedBtn.disabled = true;
            }
        }

        // --- Event Delegation ---
        document.getElementById('app-container').addEventListener('click', function(e) {
            const target = e.target.closest('.action-btn, .nav-btn');
            if (!target) return;

            const { action, target: targetScreen, from, to, place, amount, seatNumber } = target.dataset;

            if (target.classList.contains('nav-btn')) {
                navigateTo(targetScreen);
                return;
            }

            switch(action) {
                case 'navigate':
                    if (targetScreen === 'bus-details') renderBusDetailsScreen();
                    if (targetScreen === 'ticket-type') renderTicketTypeScreen();
                    if (targetScreen === 'seat-selection') renderSeatSelectionScreen();
                    if (targetScreen === 'standing-booking') renderStandingBookingScreen();
                    navigateTo(targetScreen);
                    break;
                case 'find-bus':
                    bookingState.from = from || document.getElementById('from-input').value || 'T. Nagar';
                    bookingState.to = to || document.getElementById('to-input').value || 'Guindy';
                    updateSearchResultsScreen();
                    navigateTo('search-results');
                    break;
                case 'quick-book':
                    bookingState.from = appData.frequentPlaces[place];
                    bookingState.to = place === 'home' ? appData.frequentPlaces.work : appData.frequentPlaces.home;
                    document.getElementById('from-input').value = bookingState.from;
                    document.getElementById('to-input').value = bookingState.to;
                    updateSearchResultsScreen();
                    navigateTo('search-results');
                    break;
                case 'standing-change':
                    let newCount = bookingState.ticket.count + parseInt(amount);
                    if (newCount >= 1 && newCount <= 5) {
                        bookingState.ticket.count = newCount;
                        bookingState.ticket.price = newCount * 15;
                        updateStandingSummary();
                    }
                    break;
                case 'select-seat':
                    if (target.classList.contains('booked')) return;
                    document.querySelectorAll('.seat.selected').forEach(s => s.classList.remove('selected'));
                    
                    const num = parseInt(seatNumber);
                    if (bookingState.ticket.seatNumber === num) {
                        bookingState.ticket.seatNumber = null;
                        bookingState.ticket.price = 0;
                    } else {
                        target.classList.add('selected');
                        bookingState.ticket.seatNumber = num;
                        bookingState.ticket.price = appData.busDetails.seatPrice;
                    }
                    updateSeatSummary();
                    break;
                case 'pay':
                    const overlay = document.getElementById('processing-overlay');
                    overlay.classList.remove('hidden');
                    overlay.classList.add('flex');
                    setTimeout(() => {
                        overlay.classList.add('hidden');
                        renderConfirmationScreen();
                        navigateTo('confirmation');
                    }, 2000);
                    break;
            }
        });

        // --- DOM Initialization ---
        document.addEventListener('DOMContentLoaded', () => {
            renderHomeScreen();
            navigateTo('home');
        });
    </script>
</body>
</html>
